<!DOCTYPE html>
<html
  x-data="{colorMode: 'dark'}"
  x-init="$watch('colorMode', val => localStorage.setItem('colorMode', 'dark'))"
  x-bind:class="{'dark': colorMode === 'dark'}"
  class="scroll-smooth"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      <%= assigns[:page_title] || "Hardcore Handyman of Lawton" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <%!-- For the tailwind UI font family, see: https://tailwindui.com/documentation --%>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js">
    </script>
    <%!-- See; https://michalsnik.github.io/aos/ --%>
    <script src="https://unpkg.com/aos@next/dist/aos.js">
    </script>
    <script>
      AOS.init({
        offset: 50,
        duration: 800
      });
    </script>
  </head>
  <body
    x-data="{'openDialogId': ''}"
    x-on:keydown.escape="openDialogId=''"
    class="font-body antialiased text-[#ffffff] bg-[#000000]"
    data-aos-easing="ease"
    data-aos-duration="800"
    data-aos-delay="0"
  >
    <header class="px-4 sm:px-6 lg:px-8 bg-gray-900">
      <nav id="homenav">
        <div class="dark:bg-gray-900">
          <div class="px-4 py-5 mx-auto sm:max-w-xl md:max-w-full lg:max-w-screen-xl md:px-24 lg:px-8">
            <div class="relative grid items-center grid-cols-2 lg:grid-cols-3">
              <ul class="items-center hidden space-x-8 lg:flex">
                <li>
                  <a
                    class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                    href="/#pastjobs"
                  >
                    My Work
                  </a>
                </li>
                <li>
                  <a
                    class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                    href="/#services"
                  >
                    What I Do
                  </a>
                </li>
                <li>
                  <a
                    class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                    href="/#whoiam"
                  >
                    Who I Am
                  </a>
                </li>
              </ul>
              <%!-- Link to "WHO I AM" section --%>
              <a class="inline-flex items-center lg:mx-auto" href={~p"/"}>
                <span class="ml-2 text-xl font-bold tracking-wide uppercase">
                  HARDCORE HANDYMAN OF LAWTON
                </span>
              </a>
              <ul class="items-center hidden ml-auto space-x-8 lg:flex">
                <li>
                  <a
                    class="rounded-md bg-white/10 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-white/20"
                    href="https://revenuelink.net"
                  >
                    Looking for a website?
                  </a>
                </li>
                <li>
                  <.link navigate={~p"/quote"}>
                    <button class="bg-blue-700 !important text-white px-4 py-2 rounded-lg font-semibold">
                      Get A Quote
                    </button>
                  </.link>
                </li>
              </ul>
              <div x-data="{open: false}" class="relative flex justify-end lg:hidden">
                <div
                  class="inline-flex justify-center rounded-md px-4 py-2 text-sm font-medium dark:text-white hover:bg-opacity-30"
                  x-on:click="open = !open"
                >
                  <span class="w-fit">
                    <svg class="w-5 text-gray-600" class="w-5 text-gray-600" viewBox="0 0 24 24">
                      <path
                        fill="currentColor"
                        d="M23,13H1c-0.6,0-1-0.4-1-1s0.4-1,1-1h22c0.6,0,1,0.4,1,1S23.6,13,23,13z"
                      >
                      </path>
                      <path
                        fill="currentColor"
                        d="M23,6H1C0.4,6,0,5.6,0,5s0.4-1,1-1h22c0.6,0,1,0.4,1,1S23.6,6,23,6z"
                      >
                      </path>
                      <path
                        fill="currentColor"
                        d="M23,20H1c-0.6,0-1-0.4-1-1s0.4-1,1-1h22c0.6,0,1,0.4,1,1S23.6,20,23,20z"
                      >
                      </path>
                    </svg>
                  </span>
                </div>
                <ul
                  class="absolute right-0 text-gray-900 w-56 origin-top-right bg-white divide-y divide-gray-100 rounded-md shadow-lg mt-10"
                  x-show="open"
                >
                  <li
                    x-on:click="open = false"
                    class="group flex rounded-md items-center w-full px-2 py-2 text-sm"
                  >
                    <a
                      class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                      href="/#services"
                    >
                      What I Do
                    </a>
                  </li>
                  <li
                    x-on:click="open = false"
                    class="group flex rounded-md items-center w-full px-2 py-2 text-sm"
                  >
                    <a
                      class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                      href="/#whoiam"
                    >
                      Who I Am
                    </a>
                  </li>
                  <li
                    x-on:click="open = false"
                    class="group flex rounded-md items-center w-full px-2 py-2 text-sm"
                  >
                    <a
                      class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                      href="/#pastjobs"
                    >
                      My Work
                    </a>
                  </li>
                  <li
                    x-on:click="open = false"
                    class="group flex rounded-md items-center w-full px-2 py-2 text-sm"
                  >
                    <a
                      class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                      href="https://revenuelink.net"
                    >
                      Need a website or custom app?
                    </a>
                  </li>
                  <li
                    x-on:click="open = false"
                    class="group flex rounded-md items-center w-full px-2 py-2 text-sm"
                  >
                    <.link
                      class="font-medium tracking-wide transition-colors duration-200 hover:text-teal-accent-400"
                      href={~p"/quote"}
                    >
                      Get a Quote
                    </.link>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </nav>
    </header>
    <%= @inner_content %>
    <footer>
      <div>
        <div class="py-16 text-center max-w-7xl mx-auto">
          <h1 class="text-3xl font-semibold">Hardcore Handyman of Lawton</h1>
          <p class="w-4/5 mx-auto my-5 md:w-3/5 lg:w-2/5">
            We're ready to help you enjoy your home again
          </p>
          <div class="flex justify-center gap-x-3">
            <a href="https://z-upload.facebook.com/HardcoreHandyman92/about/?referrer=services_landing_page">
              <span class="w-full text-xl border border-gray-600">
                <div style="font-size:inheritcolor:inheritpadding:2px">
                  <svg
                    stroke="currentColor"
                    fill="currentColor"
                    stroke-width="0"
                    viewBox="0 0 512 512"
                    height="1em"
                    width="1em"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path d="M504 256C504 119 393 8 256 8S8 119 8 256c0 123.78 90.69 226.38 209.25 245V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.28c-30.8 0-40.41 19.12-40.41 38.73V256h68.78l-11 71.69h-57.78V501C413.31 482.38 504 379.78 504 256z">
                    </path>
                  </svg>
                </div>
              </span>
            </a>
          </div>
        </div>
        <div class="text-center py-1 max-w-7xl mx-auto border-t border-gray-200 dark:border-gray-600">
          <p class="w-4/5 mx-auto my-5 text-sm leading-5">
            @ 2023, Hardcore Handyman of Lawton LLC. All Rights Reserved
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
